# TradeData Pro 生产环境配置
# 复制为 .env 并填入真实值

# ========== 数据库 ==========
# Render PostgreSQL 会自动提供这个URL
DATABASE_URL=postgresql://user:pass@host:5432/tradedata

# ========== 安全配置 ==========
# 生成强密钥: openssl rand -hex 32
SECRET_KEY=your-production-secret-key-here-change-me

# ========== JWT配置 ==========
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ========== 管理员配置 ==========
ADMIN_KEY=your-secure-admin-key-not-trade888

# ========== 支付配置（微信/支付宝官方）==========
# 微信支付
WECHAT_MCH_ID=your_merchant_id
WECHAT_API_KEY=your_api_key
WECHAT_APP_ID=your_app_id

# 支付宝
ALIPAY_APP_ID=your_app_id
ALIPAY_PRIVATE_KEY=your_private_key
ALIPAY_PUBLIC_KEY=alipay_public_key

# ========== 第三方数据API ==========
# 汇率API (fixer.io 或 exchangerate-api.com)
EXCHANGE_RATE_API_KEY=your_key

# 海关数据API（如有）
CUSTOMS_API_KEY=your_key
