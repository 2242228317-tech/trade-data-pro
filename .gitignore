# OpenClaw 工作区忽略文件

# 压缩包
*.zip
*.7z
*.tar.gz

# 临时文件
*.tmp
*.temp
*.log

# 编辑器
.vscode/
.idea/
*.swp
*.swo

# 系统文件
.DS_Store
Thumbs.db

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg
*.egg-info/
dist/
build/

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 大文件/二进制
*.exe
*.dll
*.bin

# 敏感信息（如果有）
.env
.env.local
*.key
*.pem
